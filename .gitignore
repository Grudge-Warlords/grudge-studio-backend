# ─── SECRETS (NEVER COMMIT) ────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
id_rsa*
id_ed25519*
.coolify-token
*.token

# ─── BACKUP / TEMP FILES ─────────────────────────────────
*.bak
*.bak.*
*.yml.bak.*
-w

# ─── DEPENDENCIES ─────────────────────────────────────────
node_modules/
services/*/node_modules/
package-lock.json

# ─── BUILD / OUTPUT ───────────────────────────────────────
*.log
*.pid
dist/
.cache/
.wrangler/

# ─── SERVER BINARIES ─────────────────────────────────────
# Never commit the Linux server binary - deploy separately
services/grudge-headless/bin/*
!services/grudge-headless/bin/.gitkeep

# ─── HEALTH REPORTS ──────────────────────────────────────
scripts/health-report.json

# ─── OS FILES ────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ─── Tunnel/binary clutter (added 2026-04-28) ────────────────
cloudflare/credentials.json
cloudflare/config.yml
cloudflared.deb
*.bak
*.bak.*
