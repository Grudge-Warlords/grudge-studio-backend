# ─── SECRETS (NEVER COMMIT) ────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
id_rsa*
id_ed25519*

# ─── DEPENDENCIES ─────────────────────────────────────────
node_modules/
services/*/node_modules/
package-lock.json

