# ═══════════════════════════════════════════════════════════════
# GRUDGE STUDIO — Environment Template
# Copy to .env and fill in real values. NEVER commit .env
# Run: node scripts/gen-secrets.js > .env  (auto-generates randoms)
# ═══════════════════════════════════════════════════════════════

# ─── NODE ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MYSQL (Docker-local game services) ───────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=grudge_game
MYSQL_USER=grudge_admin
MYSQL_PASSWORD=change_me_db

# ─── REDIS ────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis
# Local dev (non-Docker): redis://:change_me_redis@localhost:6379
# Docker sets REDIS_URL automatically via docker-compose

# ─── JWT & SESSION ────────────────────────────────────────────
# Generate: node scripts/gen-secrets.js > .env
JWT_SECRET=change_me_jwt_secret_64_chars_minimum
SESSION_SECRET=change_me_session_secret_64_chars_minimum
TOKEN_ENCRYPTION_KEY=change_me_32_char_encryption_key
ADMIN_PASSCODE=change_me_admin_passcode
ADMIN_SESSION_SECRET=change_me_admin_session_secret_64_chars_minimum

# ─── INTERNAL SERVICES ────────────────────────────────────────
INTERNAL_API_KEY=change_me_internal_key
LAUNCH_TOKEN_SECRET=change_me_launch_token_secret_64_chars

# ─── CORS ORIGINS ─────────────────────────────────────────────
CORS_ORIGINS=https://grudgewarlords.com,https://www.grudgewarlords.com,https://grudge-studio.com,https://grudgestudio.com,https://client.grudge-studio.com,https://wallet.grudge-studio.com,https://grudge-platform.vercel.app,https://grudgeplatform.com,https://www.grudgeplatform.com,https://grudachain.grudgestudio.com,https://grudachain-rho.vercel.app,https://dash.grudge-studio.com,https://warlord-crafting-suite.vercel.app,https://gdevelop-assistant.vercel.app,https://gruda-wars.vercel.app,https://grudge-engine-web.vercel.app,https://starwaygruda-webclient-as2n.vercel.app,https://app.puter.com,https://molochdagod.github.io

# ─── GAME SERVER ──────────────────────────────────────────────
MAX_PLAYERS=22

# ─── DOMAINS ──────────────────────────────────────────────────
DOMAIN_ID=id.grudge-studio.com
DOMAIN_API=api.grudge-studio.com
DOMAIN_ACCOUNT=account.grudge-studio.com
DOMAIN_LAUNCHER=launcher.grudge-studio.com
DOMAIN_WS=ws.grudge-studio.com
DOMAIN_DASH=dash.grudge-studio.com
DOMAIN_CLIENT=client.grudge-studio.com
DOMAIN_WALLET=wallet.grudge-studio.com

# ════════════════════════════════════════════════════════════════
# DATABASE — MySQL is the canonical DB (see MYSQL_* vars above)
# ════════════════════════════════════════════════════════════════
# All game data, accounts, sessions use MySQL via Docker.
# Neon PostgreSQL and Supabase have been removed — single source of truth.

# ════════════════════════════════════════════════════════════════
# OBJECT STORAGE (S3-compatible)
# ════════════════════════════════════════════════════════════════
OBJECT_STORAGE_ENDPOINT=https://s3.your-provider.com
OBJECT_STORAGE_BUCKET=grudge-studio-assets
OBJECT_STORAGE_KEY=your_access_key
OBJECT_STORAGE_SECRET=your_secret_key
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PUBLIC_URL=https://assets.grudge-studio.com

# ════════════════════════════════════════════════════════════════
# AI SERVICES
# ════════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...
DEEPSEEK_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...
MESHY_API_KEY=msy_...
HUGGINGFACE_API_KEY=hf_...
API_TRIPO=tsk_...

# ════════════════════════════════════════════════════════════════
# NFT & WALLETS (Crossmint)
# ════════════════════════════════════════════════════════════════
# ⚠ SERVER-SIDE ONLY — NEVER expose to frontend
CROSSMINT_SERVER_API_KEY=sk_production_...
CROSSMINT_PROJECT_ID=your_crossmint_project_id
# Frontend-safe Crossmint keys
VITE_CROSSMINT_CLIENT_KEY=ck_production_...
VITE_CROSSMINT_PROJECT_ID=your_crossmint_project_id
VITE_CROSSMINT_CHARACTER_COLLECTION=your_character_collection_id
VITE_CROSSMINT_ISLAND_COLLECTION=your_island_collection_id
VITE_CROSSMINT_ENV=production

# ════════════════════════════════════════════════════════════════
# SOLANA / WEB3
# ════════════════════════════════════════════════════════════════
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
GBUX_TOKEN_ADDRESS=your_gbux_token_mint_address
AI_AGENT_SOL_ADDRESS=your_ai_agent_wallet_address
# ⚠ CRITICAL: Move to AWS KMS or HashiCorp Vault for production
AI_AGENT_WALLET_SECRET_KEY=your_base58_solana_private_key
ADMIN_PRIVATE_KEY=your_admin_evm_private_key
# Generate: node -e "const {generateMnemonic}=require('bip39');console.log(generateMnemonic(256))"
WALLET_MASTER_SEED=24_word_bip39_mnemonic_phrase_goes_here

# ════════════════════════════════════════════════════════════════
# DISCORD
# ════════════════════════════════════════════════════════════════
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://id.grudge-studio.com/auth/discord/callback

# Default app redirect after OAuth login (fallback if no redirect_uri in request)
DEFAULT_AUTH_REDIRECT=https://grudgewarlords.com/auth
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_main_guild_id
DISCORD_GRUDGE_GUILD_ID=your_grudge_guild_id
# Webhooks
DISCORD_GAME_EVENTS_WEBHOOK_TOKEN=https://discord.com/api/webhooks/id/token
DISCORD_GBUX_WEBHOOK_TOKEN=https://discord.com/api/webhooks/id/token
DISCORD_GRUDA_WEBHOOK_TOKEN=https://discord.com/api/webhooks/id/token
DISCORD_MARKETPLACE_WEBHOOK_TOKEN=https://discord.com/api/webhooks/id/token
DISCORD_SYSTEM_WEBHOOK_TOKEN=https://discord.com/api/webhooks/id/token
# Frontend-safe
VITE_DISCORD_CLIENT_ID=your_discord_client_id

# ════════════════════════════════════════════════════════════════
# PUTER CLOUD — GRUDACHAIN account (server-side) + PIP monetisation
# ════════════════════════════════════════════════════════════════
#
#  GRUDGE STUDIO uses Puter in two distinct roles:
#
#  1. GRUDACHAIN (server-side / me.puter)
#     → Legion AI backend, admin KV/FS storage, GRD-17 node ops
#     → Authenticated server-side via PUTER_AUTH_TOKEN below
#
#  2. PLAYER ACCOUNTS (client-side / user.puter)
#     → Every player gets their own Puter account (auto-created
#       as temp on first visit via attempt_temp_user_creation)
#     → Players' puter.ai + puter.kv + puter.fs usage generates
#       Puter Incentive Program (PIP) REVENUE for GRUDGE STUDIO
#     → Handled entirely client-side by puter-onboarding.ts
#
#  Get PUTER_AUTH_TOKEN:
#    1. Sign in to puter.com as the GRUDACHAIN account
#    2. puter.com/dashboard → Copy auth token
#    OR: puter-cli auth  (installs via: npm i -g @heyputer/puter-cli)

# GRUDACHAIN server auth token — used by Node.js SDK: init(PUTER_AUTH_TOKEN)
PUTER_AUTH_TOKEN=get_from_puter.com_dashboard_grudachain_account

# Puter API base (only change for self-hosted Puter instance)
PUTER_BASE_URL=https://api.puter.com

# Puter App ID — register at puter.com/app-center for PIP monetisation
# Every user interaction with Puter features earns monthly PIP revenue
PUTER_APP_ID=your_grudge_studio_puter_app_id

ENABLE_PUTER_CLOUD=true

# ════════════════════════════════════════════════════════════════
# FIREBASE
# ════════════════════════════════════════════════════════════════
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ════════════════════════════════════════════════════════════════
# WEB3AUTH
# ════════════════════════════════════════════════════════════════
WEB3AUTH_CLIENT_ID=your_web3auth_client_id
VITE_WEB3AUTH_CLIENT_ID=your_web3auth_client_id
VITE_WEB3AUTH_NETWORK=sapphire_devnet

# ════════════════════════════════════════════════════════════════
# GITHUB (OAuth + API)
# ════════════════════════════════════════════════════════════════
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URI=https://id.grudge-studio.com/auth/github/callback
GITHUB_TOKEN=github_pat_...

# ════════════════════════════════════════════════════════════════
# GOOGLE (OAuth)
# ════════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://id.grudge-studio.com/auth/google/callback

# ════════════════════════════════════════════════════════════════
# TWILIO (SMS / 2FA)
# ════════════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ════════════════════════════════════════════════════════════════
# MISC SERVICES
# ════════════════════════════════════════════════════════════════
GDEVELOP_API_KEY=your_gdevelop_api_key
GAME_API_GRUDA=your_game_api_key
SOLSCAN_API_KEY=your_solscan_api_key

# ════════════════════════════════════════════════════════════════
# COLYSEUS (Game Server)
# ════════════════════════════════════════════════════════════════
COLYSEUS_CLOUD_TOKEN=your_colyseus_cloud_token

# ----------------------------------------------------------------
# GEMINI (Google � free tier: 15 RPM, 1M tokens/day)
# ----------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ----------------------------------------------------------------
# OLLAMA (Free self-hosted LLM)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull llama3.2
# ----------------------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ════════════════════════════════════════════════════════════════
# CROSS-SERVICE IDENTITY
# ════════════════════════════════════════════════════════════════
# URL of the grudge-id service (id.grudge-studio.com)
# Used by grudaLegion.ts proxy for /api/grudge-id/* routes
GRUDGE_ID_URL=https://id.grudge-studio.com


