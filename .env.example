# ============================================================
# Grudge Studio Backend — Environment Variables
# Copy to .env and fill in real values.
# Generate secrets: node scripts/gen-secrets.js > .env
# ============================================================

# ── Database (MySQL 8) ──
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=grudge_game
MYSQL_USER=grudge
MYSQL_PASSWORD=

# ── Redis ──
REDIS_PASSWORD=

# ── Auth / JWT ──
JWT_SECRET=                         # 64+ char random string
INTERNAL_API_KEY=                   # service-to-service auth
LAUNCH_TOKEN_SECRET=                # one-time game launch tokens

# ── Discord OAuth ──
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://id.grudge-studio.com/auth/discord/callback

# ── Google OAuth (Phase 2 — leave blank to disable) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://id.grudge-studio.com/auth/google/callback

# ── GitHub OAuth (Phase 2 — leave blank to disable) ──
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://id.grudge-studio.com/auth/github/callback

# ── Web3Auth ──
WEB3AUTH_CLIENT_ID=

# ── Blockchain ──
WALLET_MASTER_SEED=                 # 24-word BIP39 mnemonic
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Cloudflare R2 Object Storage ──
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=grudge-assets
OBJECT_STORAGE_KEY=
OBJECT_STORAGE_SECRET=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_PUBLIC_URL=
CF_ACCOUNT_ID=

# ── Cloudflare Tunnel (replaces Traefik for public ingress) ──
# Create at https://one.dash.cloudflare.com → Networks → Tunnels
# Copy the "Install connector" token (base64 string). This alone
# is enough — ingress is managed from the dashboard's Public
# Hostnames tab. See deploy/MIGRATE-TO-CLOUDFLARE-TUNNEL.md.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Cloudflare Turnstile ──
CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=

# ── Cloudflare KV (for R2 CDN worker rate limiting) ──
CF_KV_RATE_LIMIT_ID=

# ── AI Agent ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── Crossmint (NFT) ──
CROSSMINT_API_KEY=
CROSSMINT_ENV=production
CROSSMINT_COLLECTION_ID=

# ── Grudge Bridge ──
BRIDGE_API_KEY=
BRIDGE_PEER_NODES=

# ── Discord Webhook (alerts) ──
DISCORD_WEBHOOK_URL=

# ── Puter ──
PUTER_AUTH_TOKEN=
PUTER_USERNAME=GRUDACHAIN
