# ─── MYSQL ────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=grudge_game
MYSQL_USER=grudge_admin
MYSQL_PASSWORD=change_me_db

# ─── REDIS ────────────────────────────────
REDIS_PASSWORD=change_me_redis
# Note: REDIS_URL is constructed automatically in docker-compose.
# For local dev (non-Docker): redis://:change_me_redis@localhost:6379

# ─── JWT ──────────────────────────────────
# Generate with: node scripts/gen-secrets.js > .env
JWT_SECRET=change_me_jwt_secret_64_chars_minimum

# ─── DISCORD AUTH ─────────────────────────
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://id.grudgestudio.com/auth/discord/callback

# ─── WEB3AUTH ─────────────────────────────
WEB3AUTH_CLIENT_ID=your_web3auth_client_id

# ─── SOLANA / WALLET SERVICE ──────────────
# Generate with: node -e "const {generateMnemonic}=require('bip39');console.log(generateMnemonic(256))"
WALLET_MASTER_SEED=24_word_bip39_mnemonic_phrase_goes_here
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── INTERNAL SERVICES ────────────────────
# Generate with: node scripts/gen-secrets.js > .env
INTERNAL_API_KEY=change_me_internal_key

# ─── GAME SERVER ──────────────────────────
MAX_PLAYERS=22

# ─── CORS ORIGINS ─────────────────────────
# Comma-separated list of allowed origins.
# Add your GitHub Pages URL, puter app URL, or ObjectStore app URL here.
CORS_ORIGINS=https://grudgewarlords.com,https://grudgestudio.com,https://grudachain.grudgestudio.com

# ─── OBJECT STORAGE ───────────────────────
# S3-compatible: Cloudflare R2, Backblaze B2, ObjectStore, AWS S3, etc.
OBJECT_STORAGE_ENDPOINT=https://s3.your-provider.com
OBJECT_STORAGE_BUCKET=grudge-studio-assets
OBJECT_STORAGE_KEY=your_access_key
OBJECT_STORAGE_SECRET=your_secret_key
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PUBLIC_URL=https://assets.grudgestudio.com

# ─── LAUNCH TOKEN ──────────────────────
# Separate secret for one-time game launch tokens (5 min TTL).
# Generate with: node scripts/gen-secrets.js > .env
LAUNCH_TOKEN_SECRET=change_me_launch_token_secret_64_chars

# ─── PUTER ─────────────────────────────
# Puter.com App ID for client-side puter.js SDK initialization.
PUTER_APP_ID=your_puter_app_id

# ─── DOMAINS ───────────────────────────
DOMAIN_ID=id.grudgestudio.com
DOMAIN_API=api.grudgestudio.com
DOMAIN_ACCOUNT=account.grudgestudio.com
DOMAIN_LAUNCHER=launcher.grudgestudio.com
DOMAIN_WS=ws.grudgestudio.com
